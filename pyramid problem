def series_term(n):
    return 8 * n * n - 2 * n

N = int(input())
total_numbers = N * (N + 1) // 2
series = []
for i in range (1,total_numbers + 1):
    series.append(series_term(i))
    index = 0
for row in range(1, N + 1):
    current_row = []
    for col in range(row):
        current_row.append(f"{series[index]:05d}")
        index += 1
            
print(" ".join(current_row))

